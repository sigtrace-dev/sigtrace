    "@babel/generator": "^7.22.0",
    "@babel/types": "^7.22.0"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0",
    "vue": "^3.3.0",
    "@angular/core": ">=17.0.0",
    "@preact/signals-react": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "solid-js": "^1.8.0",
    "vue": "^3.3.0",
    "@angular/core": ">=17.0.0",
    "@preact/signals-react": "^2.0.0",
    "svelte": "^5.0.0"
