{
  "name": "sigtrace-extension",
  "displayName": "SigTrace",
  "description": "Universal Reactive Graph & Signal Lifecycle Tracer",
  "version": "1.0.8",
  "publisher": "sigtrace",
  "icon": "icon.jpg",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigtrace-dev/sigtrace.git"
  },
  "files": [
    "dist/**/*.js",
    "src/webview/**/*",
    "package.json",
    "LICENSE",
    "icon.jpg"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sigtrace-container",
          "title": "SigTrace",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "sigtrace-container": [
        {
          "type": "webview",
          "id": "sigtrace-explorer",
          "name": "Reactivity Visualizer",
          "icon": "$(graph)",
          "contextualTitle": "SigTrace Explorer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --platform=node --target=node16.14 --external:vscode --outfile=dist/extension.js",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node16.14 --external:vscode --outfile=dist/extension.js --watch"
  },
  "dependencies": {
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.5.5",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}
