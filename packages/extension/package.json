{
  "name": "sigtrace-extension",
  "displayName": "SigTrace",
  "description": "Angular, Vue, and Solid signals debugger for VS Code",
  "version": "1.1.6",
  "publisher": "sigtrace",
  "author": "SigTrace Contributors",
  "license": "MIT",
  "homepage": "https://sigtrace.dev",
  "bugs": {
    "url": "https://github.com/sigtrace-dev/sigtrace/issues"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigtrace-dev/sigtrace.git"
  },
  "files": [
    "dist/**/*.js",
    "src/webview/**/*",
    "package.json",
    "LICENSE",
    "icon.png",
    "assets/**/*.svg"
  ],
  "categories": [
    "Debuggers",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "angular",
    "signals",
    "reactivity",
    "debugging",
    "vue",
    "solidjs",
    "devtools",
    "visualizer",
    "causal chain",
    "angular signals debugger",
    "vue ref debugger",
    "solidjs debugger",
    "signal not updating"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sigtrace-container",
          "title": "SigTrace",
          "icon": "assets/sigtrace-icon.svg"
        }
      ]
    },
    "views": {
      "sigtrace-container": [
        {
          "type": "webview",
          "id": "sigtrace-explorer",
          "name": "Signal Debugger",
          "icon": "$(graph)",
          "contextualTitle": "SigTrace Signal Debugger"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --platform=node --target=node16.14 --external:vscode --outfile=dist/extension.js",
    "watch": "esbuild src/extension.ts --bundle --platform=node --target=node16.14 --external:vscode --outfile=dist/extension.js --watch"
  },
  "dependencies": {
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.5.5",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0"
  }
}